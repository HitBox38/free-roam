{
  "name": "free-roam",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit",
    "spacetime:dev": "spacetime dev free-roam-97kss --server maincloud --module-path spacetimedb/spacetimedb --module-bindings-path src/module_bindings",
    "spacetime:build": "spacetime build --module-path spacetimedb/spacetimedb",
    "spacetime:generate": "spacetime generate free-roam-97kss --lang typescript --out-dir src/module_bindings --module-path spacetimedb/spacetimedb --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
